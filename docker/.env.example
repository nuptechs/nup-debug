# ====================================================
# nup-sentinel-probe — Consumer .env template
# Copy to .env and fill the required values, then run:
#   docker compose -f docker/docker-compose.example.yml up -d
# ====================================================

# ---- Central Sentinel federation (REQUIRED) ----
# Where the central Sentinel orchestrator lives. Default points to NupTechs HML.
SENTINEL_URL=https://sentinel.nuptechs.com

# Tenant-scoped API key issued by the Sentinel admin (format: nup_sentinel_*)
SENTINEL_API_KEY=

# Sentinel project slug for this consumer (e.g. "nup-school", "easynup")
SENTINEL_PROJECT_ID=

# Optional: explicit org id (auto-resolved from API key if omitted)
SENTINEL_ORG_ID=

# ---- Probe ingest auth (REQUIRED) ----
# Shared secret your application instrumentation will send when reporting
# events to the local probe (header: X-Probe-API-Key).
# Generate with: openssl rand -hex 32
PROBE_INGEST_API_KEY=

# ---- Local probe Postgres (REQUIRED) ----
PROBE_POSTGRES_DB=probe
PROBE_POSTGRES_USER=probe
PROBE_POSTGRES_PASSWORD=
