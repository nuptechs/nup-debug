{
  "name": "@nuptechs/sentinel-probe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NuP Sentinel Probe — runtime capture module of the NuP Sentinel platform.",
  "workspaces": [
    "packages/*",
    "server",
    "dashboard",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
